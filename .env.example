# Copy to .env and fill in. .env is gitignored.

# --- Teacher / Judge (OpenAI-compatible) ---
OPENAI_API_KEY=sk-...
# Model used to generate configs, conversations, and to judge/eval.
OPENAI_MODEL=gpt-4o
# Optional: point at an OpenAI-compatible endpoint (Azure, local vLLM, etc.).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Concurrency / rate limiting for data generation.
TEACHER_MAX_CONCURRENCY=6

# --- Base model to fine-tune (used by train.py / eval.py) ---
BASE_MODEL=Qwen/Qwen3-1.7B

# Path to the tuned adapter/model (produced by train.py; consumed by eval.py).
TUNED_MODEL=outputs/persona-boundary-qlora
